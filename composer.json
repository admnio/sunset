{
  "name": "admnio/sunset",
  "description": "Sunset for Laravel — supercharged Horizon replacement. v0.2.0: SQS transport.",
  "type": "library",
  "license": "MIT",
  "require": {
    "php": "^8.2",
    "aws/aws-sdk-php": "^3.300",
    "illuminate/queue": "^10.0 || ^11.0 || ^12.0",
    "illuminate/redis": "^10.0 || ^11.0 || ^12.0",
    "illuminate/support": "^10.0 || ^11.0 || ^12.0",
    "inertiajs/inertia-laravel": "^1.0",
    "ramsey/uuid": "^4.7",
    "vladimir-yuldashev/laravel-queue-rabbitmq": "^14.0"
  },
  "require-dev": {
    "orchestra/testbench": "^8.0 || ^9.0 || ^10.0",
    "phpunit/phpunit": "^10.5 || ^11.0",
    "mockery/mockery": "^1.6"
  },
  "autoload": {
    "psr-4": {
      "Admnio\\Sunset\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Admnio\\Sunset\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Admnio\\Sunset\\SunsetServiceProvider"
      ]
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
